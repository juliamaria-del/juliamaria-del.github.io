<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Semana de Inovação e Tecnologia — IFAL</title>
  <!--
    ATENÇÃO: este arquivo HTML NÃO deve ser modificado.
    Toda a atividade é resolvida exclusivamente no arquivo atv01.css.
  -->
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <header class="cabecalho">
    <h1>Semana de Inovação e Tecnologia</h1>
    <p class="subtitulo">Instituto Federal de Alagoas — Campus Maceió</p>
    <nav class="menu">
      <ul>
        <li><a href="#sobre">Sobre</a></li>
        <li><a href="#trilhas">Trilhas</a></li>
        <li><a href="#programacao">Programação</a></li>
        <li><a href="#inscricao">Inscrição</a></li>
      </ul>
    </nav>
  </header>

  <main>

    <section id="sobre" class="secao">
      <h2>Sobre o evento</h2>
      <p>A Semana de Inovação e Tecnologia reúne estudantes, docentes e profissionais em torno de palestras, oficinas e maratonas de desenvolvimento.</p>
      <p>São cinco dias de atividades gratuitas, distribuídas em quatro trilhas temáticas.</p>
      <p class="destaque">As inscrições são limitadas e encerram na sexta-feira anterior ao evento.</p>
    </section>

    <section id="trilhas" class="secao">
      <h2>Trilhas temáticas</h2>
      <div class="grade">
        <article class="cartao">
          <h3>Desenvolvimento Web</h3>
          <p>Fundamentos de HTML, CSS e JavaScript aplicados à construção de interfaces.</p>
          <a href="#inscricao" class="botao">Inscrever-se</a>
        </article>
        <article class="cartao">
          <h3>Ciência de Dados</h3>
          <p>Coleta, tratamento e visualização de dados com ferramentas livres.</p>
          <a href="#inscricao" class="botao">Inscrever-se</a>
        </article>
        <article class="cartao">
          <h3>Internet das Coisas</h3>
          <p>Prototipagem de dispositivos conectados com microcontroladores.</p>
          <a href="#inscricao" class="botao">Inscrever-se</a>
        </article>
        <article class="cartao">
          <h3>Segurança da Informação</h3>
          <p>Princípios de proteção de sistemas, redes e dados pessoais.</p>
          <a href="#inscricao" class="botao">Inscrever-se</a>
        </article>
      </div>
    </section>

    <section id="programacao" class="secao">
      <h2>Programação por dia</h2>
      <ul class="lista-dias">
        <li>Segunda-feira — Abertura
          <ul>
            <li>Credenciamento</li>
            <li>Palestra de abertura</li>
          </ul>
        </li>
        <li>Terça-feira — Oficinas
          <ul>
            <li>Oficina de HTML semântico</li>
            <li>Oficina de CSS responsivo</li>
          </ul>
        </li>
        <li>Quarta-feira — Maratona
          <ul>
            <li>Formação de equipes</li>
            <li>Desenvolvimento orientado</li>
          </ul>
        </li>
      </ul>
    </section>

    <section id="inscricao" class="secao">
      <h2>Inscrição</h2>
      <p>Preencha os dados abaixo para garantir sua vaga.</p>
      <form class="formulario">
        <label for="nome">Nome completo</label>
        <input type="text" id="nome" name="nome">

        <label for="email">E-mail</label>
        <input type="email" id="email" name="email">

        <label for="telefone">Telefone</label>
        <input type="tel" id="telefone" name="telefone">

        <label for="senha">Senha de acesso</label>
        <input type="password" id="senha" name="senha">

        <label for="mensagem">Observações</label>
        <textarea id="mensagem" name="mensagem" rows="4"></textarea>

        <button type="submit">Enviar inscrição</button>
      </form>
    </section>

  </main>

  <footer class="rodape">
    <p>Semana de Inovação e Tecnologia — IFAL, Campus Maceió.</p>
    <p>Contato: eventos@ifal.edu.br</p>
  </footer>

</body>
</html>

  /*
rem é relativo ao tamanho da fonte do elemento raiz (html),
em é relativo ao tamanho da fonte do próprio elemento,
e % depende do tamanho do elemento pai.
rem é ideal para tipografia, em para espaçamentos proporcionais
e % para layouts responsivos.
*/

html {
  font-size: 16px;
  }

  body {
  font-family: Arial, Helvetica, sans-serif;
  margin: 0px;
  color: #333333;
  background-color: #f5f5f5;
}

/* ---------- Cabeçalho ---------- */
.cabecalho {
  background-color: #1565c0;
  padding: 2rem;
}

h1 {
    color: #ffffff;
  font-size: 2rem;
  margin: 0px;
}

.subtitulo {
  color: #bbdefb;
  font-size: 1rem;
}

/* ---------- Menu de navegação ---------- */
.menu ul a {
  list-style: none;
  padding: 0px;
  margin: 16px 0px 0px 0px;
   color: #f4f400;
  text-decoration: none;
}

.menu li {
  display: inline-block;
  margin-right: 24px;
}

.menu a:hover {
  color: #ffeb3b;
  font-size: 1rem;
  text-decoration: none;
}

/* ---------- Seções ---------- */
.secao {
  padding: 32px;
  max-width: 60rem;
  width: 100%;
}

h2 {
 color: #1565c0;
  font-size: 1.5rem;
}

h3 {
   color: #0d47a1;
  font-size: 1.25rem;
}

p {
  font-size: 1rem;
  line-height: 24px;
}

.destaque {
  font-size: 1rem;
  font-weight: bold;
  color: #b71c1c;
}

/* ---------- Grade de trilhas ---------- */
.cartao {
  display: inline-block;
  width: 30%;
  vertical-align: top;
  border: 1px solid #cccccc;
  background-color: #ffffff;
  padding: 1em;
  margin: 0.5em;
}

.botao:hover {
  display: inline-block;
  background-color: #1565c0;
  color: #ffffff;
  font-size: 1rem;
  text-decoration: none;
  padding: 0.5em 1em;
  margin-top: 0.5em;
}

/* ---------- Lista de programação ---------- */
.lista-dias > li {
  font-size: 1rem;
  line-height: 28px;
  font-weight: bold;
}

/* ---------- Formulário ---------- */

form {
  480px;
}
.formulario {
  max-width: 100%;
}

label {
  display: block;
  font-size: 1rem;
  margin-top: 16px;
}

input:focus {
  display: block;
  width: 100%;
  font-size: 1rem;
  padding: 8px;
  margin-top: 4px;
  border: 1px solid #999999;
}

textarea:focus {
  display: block;
  width: 100%;
  font-size: 1rem;
  padding: 8px;
  margin-top: 4px;
  border: 1px solid #999999;
} 
/* Espaço seleciona qualquer descendente.
   > seleciona apenas filhos diretos. */

button {
  font-size: 1rem;
  color: #ffffff;
  background-color: #1565c0;
  padding: 8px 24px;
  margin-top: 16px;
  border: 0px;
}

/* ---------- Rodapé ---------- */
.rodape {
  background-color: #263238;
  color: #cfd8dc;
  padding: 24px;
  font-size: 0.875rem;
}

article {
 16px;
}

h2 + p {
   margin-top: 1rem;
}

 .destaque ~ p {
  color: #555555;
  font-style: italic;
}

.lista-dias > li:first-child {
  color: green;
}

.lista-dias > li:last-child {
  color: red;
}

.cartao:nth-child(odd) {
  background-color: #ffffff;
}

.cartao:nth-child(even) {
  background-color: #f0f8ff;
  font-style: italic;
}

.cartao:not(:last-child) {
  margin-bottom: 1em;
  font-style: italic;
}
/* nth-child() permite selecionar elementos pela posição,
   evitando criar classes extras no HTML. */

input[type="email"] {
  border: 2px solid green;
}

input[type="password"] {
  border: 2px solid red;
}

.menu a::before {
  content: "› ";
}

label::after {
  content: " *";
  color: red;
}

.botao {
  background-color: blue;
}

.cartao .botao {
  background-color: skyblue;
}

/* .cartao .botao possui maior especificidade
   que .botao, portanto prevalece sem precisar
   usar !important. */
